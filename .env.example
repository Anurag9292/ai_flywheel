# Database
DATABASE_URL=postgresql+asyncpg://flywheel:flywheel_dev@localhost:5433/ai_flywheel
DATABASE_URL_SYNC=postgresql://flywheel:flywheel_dev@localhost:5433/ai_flywheel

# Redis
REDIS_URL=redis://localhost:6379/0

# Temporal
TEMPORAL_HOST=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=ai-flywheel-main

# LLM Providers
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Auth (Clerk)
CLERK_SECRET_KEY=sk_test_...
CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_JWKS_URL=https://your-instance.clerk.accounts.dev/.well-known/jwks.json

# Object Storage
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=ai-flywheel

# Environment
ENVIRONMENT=development
LOG_LEVEL=DEBUG
