# Environment
ENVIRONMENT=development
LOG_LEVEL=DEBUG

# Database (PostgreSQL with pgvector)
DATABASE_URL=postgresql+asyncpg://flywheel:flywheel_dev@localhost:5433/ai_flywheel
DATABASE_URL_SYNC=postgresql://flywheel:flywheel_dev@localhost:5433/ai_flywheel

# Redis
REDIS_URL=redis://localhost:6379/0

# Temporal
TEMPORAL_HOST=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=ai-flywheel-main

# LLM Providers (at least one required)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Auth (JWT)
JWT_SECRET_KEY=change-this-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Slack Integration (optional — needed for Slack channel)
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=
SLACK_APP_TOKEN=xapp-...
SLACK_CHANNEL=

# Object Storage (MinIO for development)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=ai-flywheel
