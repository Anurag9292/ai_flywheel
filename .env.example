# Copy this file to `.env` (gitignored) and fill in real values.
# The dev server (flywheel.devserver.app) and demos auto-load `.env` from the
# repo root via python-dotenv. Shell / VS Code debugger env vars still take
# precedence (we never override an already-set var).
#
# Only the variables the code uses TODAY are listed. Infra (Redis, Temporal,
# object storage, auth) is intentionally omitted until the features that consume
# it are built — add those vars here when they land.

# --- Persistence (Neon Postgres) ---

# Connection string for the real persistence stores (Sql* stores) and Alembic
# migrations. Leave unset to use the in-memory fakes (default test/demo path).
# Neon hands out a `postgresql://` URL; resolve_db_url() rewrites it to the
# psycopg3 driver form automatically, so paste it verbatim.
# For migrations, prefer Neon's DIRECT (non-pooled) connection string.
DB_URL=postgresql://user:pass@ep-xxx.neon.tech/dbname?sslmode=require

# Which venture the dev server loads:
#   postlineai       -> fake/offline lead-gen (default; needs no keys)
#   postlineai-live  -> REAL lead-gen (requires the keys below)
FLYWHEEL_VENTURE=postlineai

# --- Required only for the LIVE venture (postlineai-live) ---

# Real LLM reasoning for the agentic lead-gen nodes (litellm). Use a NON-prod key.
OPENAI_API_KEY=sk-...
# Model passed to litellm (any litellm-supported model id).
FLYWHEEL_LLM_MODEL=gpt-4o-mini

# Career-page enrichment in lead-sourcer (Firecrawl).
FIRECRAWL_API_KEY=fc-...
