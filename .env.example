# Environment
ENVIRONMENT=development
LOG_LEVEL=DEBUG

# Database (PostgreSQL with pgvector)
DATABASE_URL=postgresql+asyncpg://flywheel:flywheel_dev@localhost:5433/ai_flywheel
DATABASE_URL_SYNC=postgresql://flywheel:flywheel_dev@localhost:5433/ai_flywheel

# Redis
REDIS_URL=redis://localhost:6379/0

# Temporal
TEMPORAL_HOST=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=ai-flywheel-main

# LLM Providers (at least one required)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Auth (Clerk) — optional for development
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=
CLERK_JWKS_URL=

# Object Storage (MinIO for development)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=ai-flywheel

# RunCord (Builder Engine) — optional
RUNCORD_API_KEY=
RUNCORD_BASE_URL=https://api.runcord.com/api/v1
